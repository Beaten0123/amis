{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "lib/**",
        "esm/**",
        "dist/**"
      ],
      "cache": true
    },
    "build-esm": {
      "dependsOn": ["^build"],
      "outputs": [
        "esm/**"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [
        "coverage/**"
      ],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "outputs": [
        "coverage/**"
      ],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
